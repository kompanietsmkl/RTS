extends DirectionalLight3D

# Длительность игровых суток в реальных минутах
@export var day_length_minutes: float = 5.0

# Текущее время суток (от 0.0 до 1.0, где 0.0 - полночь, 0.5 - полдень)
@export_range(0.0, 1.0) var time_of_day: float = 0.25 # Стартуем утром

# Скорость вращения солнца (вычисляется автоматически)
var rotation_speed: float = 0.0


func _ready() -> void:
	# Считаем, какую долю круга солнце должно проходить за одну секунду реального времени
	# В полном круге 360 градусов (или 2 * PI радиан)
	# Формула: Общий путь / (Минуты * 60 секунд)
	rotation_speed = (2.0 * PI) / (day_length_minutes * 60.0)


func _process(delta: float) -> void:
	# 1. Двигаем время вперед в зависимости от прошедшего delta-времени
	time_of_day += (rotation_speed / (2.0 * PI)) * delta
	
	# Если день закончился, сбрасываем счетчик на 0 (новые сутки)
	if time_of_day >= 1.0:
		time_of_day = 0.0
	
	# 2. Вычисляем текущий угол наклона солнца (по оси X)
	# Мы умножаем time_of_day на 360 градусов (в радианах)
	var target_angle = time_of_day * 2.0 * PI
	
	# Применяем вращение. 
	# Поворот по X симулирует восход и закат (выше/ниже к горизонту).
	# Поворот по Y (например, -45 градусов) сохранит ваш красивый изометрический ракурс света.
	rotation.x = target_angle
	rotation.y = deg_to_rad(-45.0) # Задайте тот угол по Y, который вам понравился в прошлый раз
