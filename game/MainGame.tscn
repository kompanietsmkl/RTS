[sub_resource type="GDScript" id="GDScript_rvslj"]
script/source = "@tool # Этот флаг заставляет скрипт работать прямо в редакторе!
extends GridMap

# Создаем кнопку-галочку в инспекторе справа
@export var trigger_fill: bool = false:
	set(value):
		if value == true:
			fill_the_map()
			# Сразу выключаем галочку обратно
			trigger_fill = false 

func fill_the_map() -> void:
	var width = 60
	var depth = 60
	var tile_id = 0 
	
	for x in range(-width / 2, width / 2):
		for z in range(-depth / 2, depth / 2):
			set_cell_item(Vector3i(x, 0, z), tile_id, 0)
			
	print(\"Карта успешно залита прямо в редакторе!\")
"

